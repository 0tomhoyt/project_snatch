# HarborLink Environment Variables Example
# =========================================
# Copy this file to .env and modify as needed
# Environment variables override config.yaml values

# Server Configuration
HARBORLINK_SERVER_PORT=8080
HARBORLINK_SERVER_HOST=0.0.0.0
HARBORLINK_SERVER_MODE=debug

# Database Configuration
HARBORLINK_DATABASE_HOST=localhost
HARBORLINK_DATABASE_PORT=5432
HARBORLINK_DATABASE_NAME=harborlink
HARBORLINK_DATABASE_USER=postgres
HARBORLINK_DATABASE_PASSWORD=your_password
HARBORLINK_DATABASE_SSL_MODE=disable

# Redis Configuration
HARBORLINK_REDIS_HOST=localhost
HARBORLINK_REDIS_PORT=6379
HARBORLINK_REDIS_PASSWORD=
HARBORLINK_REDIS_DB=0

# Logging Configuration
HARBORLINK_LOGGING_LEVEL=info
HARBORLINK_LOGGING_FORMAT=json

# Carrier API Keys (examples)
# HARBORLINK_CARRIERS_0_API_KEY=your_maersk_api_key
# HARBORLINK_CARRIERS_1_API_KEY=your_msc_api_key
